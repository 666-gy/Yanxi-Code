{
  "name": "yanxi-code",
  "version": "1.3.0",
  "description": "Yanxi Code -- As coding as developing",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "generate:icon": "node scripts/generate-icon.mjs",
    "dist": "npm run build && npm run generate:icon && electron-builder --win",
    "dist:portable": "npm run build && npm run generate:icon && electron-builder --win portable",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "Yanxi",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "png-to-ico": "^2.1.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.33.5",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "chokidar": "^3.6.0",
    "lucide-react": "^1.24.0",
    "marked": "^18.0.6",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.yanxi.code",
    "productName": "Yanxi Code",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/update-path.ps1",
        "to": "update-path.ps1"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "include": "build/installer.nsh",
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Yanxi Code",
      "artifactName": "Yanxi.Code.Setup.${version}.${ext}"
    },
    "portable": {
      "artifactName": "Yanxi.Code.Portable.${version}.${ext}"
    }
  }
}
